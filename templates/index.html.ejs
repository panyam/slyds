<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="<%= cssUrl %>">
    <link rel="stylesheet" href="theme.css">
</head>
<body>
    <!-- Controls bar -->
    <div class="controls-bar">
        <button class="presenter-mode-btn" onclick="openNotesWindow()">&#128221; Notes</button>
        <div class="slide-counter">
            <span id="slideNum">1</span> / <span id="totalSlides"></span>
        </div>
    </div>

    <div class="slideshow-container">

        <!-- Slide 1: Title -->
        <div class="slide active title-slide">
            <h1><%= title %></h1>
            <p style="font-size: 1.2em; margin-top: 30px; opacity: 0.85;">
                Your subtitle here
            </p>
            <div class="speaker-notes">
                <h3>Opening</h3>
                <p>Welcome everyone. Set the stage for your talk.</p>
            </div>
        </div>
<% for (var i = 0; i < contentSlides; i++) { %>

        <!-- Slide <%= i + 2 %> -->
        <div class="slide">
            <h1>Slide <%= i + 2 %></h1>
            <ul>
                <li>Key point one</li>
                <li>Key point two</li>
                <li>Key point three</li>
            </ul>
<% if (i === 0) { %>
            <div class="highlight">
                <p><strong>Highlight:</strong> Use this box for important callouts.</p>
            </div>
<% } %>
            <div class="speaker-notes">
                <h3>Talking Points</h3>
<% if (i === 0) { %>
                <ul>
                    <li>Expand on your key points here</li>
                    <li>These notes appear in a separate window (press N)</li>
                </ul>
<% } else { %>
                <p>Speaker notes for slide <%= i + 2 %>.</p>
<% } %>
            </div>
        </div>
<% } %>

        <!-- Slide <%= totalSlides %>: Closing -->
        <div class="slide conclusion-slide">
            <h1 style="border-bottom: none;">Thank You</h1>
            <div style="text-align: center; margin-top: 80px;">
                <p style="font-size: 1.4em; font-style: italic; opacity: 0.9; max-width: 700px; margin: 0 auto; line-height: 1.6;">
                    "Your closing quote or message here."
                </p>
            </div>
            <div class="speaker-notes">
                <h3>Closing</h3>
                <p>Wrap up and thank the audience.</p>
            </div>
        </div>

        <div class="navigation">
            <button class="nav-button" onclick="changeSlide(-1)" id="prevBtn">&#10094; Previous</button>
            <button class="nav-button" onclick="changeSlide(1)" id="nextBtn">Next &#10095;</button>
        </div>
    </div>

    <script src="<%= jsUrl %>"></script>
</body>
</html>
