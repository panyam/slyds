/* {{.Title}} — Dark theme
   Optimized for code-heavy talks, demos, and low-light environments. */

body {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
}

.slideshow-container {
    background: #1e1e2e;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
}

.slide {
    color: #e0e0e0;
}

.slide h1 {
    color: #e0e0e0;
    border-bottom: 4px solid #00d4ff;
}

.slide h2 {
    color: #b0b0b0;
}

.slide h3 {
    color: #00d4ff;
}

.slide p, .slide li {
    color: #c0c0c0;
}

.title-slide {
    background: linear-gradient(135deg, #1a1a2e 0%, #0f3460 100%);
    color: #e0e0e0;
}

.title-slide h1 {
    color: #ffffff;
    border-bottom: none;
    text-shadow: 0 2px 10px rgba(0, 212, 255, 0.3);
}

.conclusion-slide {
    background: linear-gradient(135deg, #16213e 0%, #1a1a2e 100%);
    color: #e0e0e0;
}

.conclusion-slide h1, .conclusion-slide h2 {
    color: #e0e0e0;
}

.section-slide {
    background: linear-gradient(135deg, #0f3460 0%, #1a1a2e 100%);
    color: #e0e0e0;
}

.section-slide h1 {
    color: #00d4ff;
    border-bottom: 3px solid #00d4ff;
}

.nav-button {
    background: #00d4ff;
    color: #1a1a2e;
}

.nav-button:hover {
    background: #00b4d8;
}

.nav-button:disabled {
    background: #333355;
    color: #666688;
}

.controls-bar {
    background: rgba(0, 0, 0, 0.5);
}

.controls-bar .presenter-mode-btn {
    background: #00d4ff;
    color: #1a1a2e;
    font-weight: 600;
}

.controls-bar .presenter-mode-btn:hover {
    background: #00b4d8;
}

.highlight {
    background: rgba(0, 212, 255, 0.1);
    border-left: 5px solid #00d4ff;
}

.stat-number {
    color: #00d4ff;
}

/* Code blocks stand out on dark backgrounds */
code, pre {
    background: #0d1117;
    color: #c9d1d9;
    padding: 2px 6px;
    border-radius: 4px;
    font-family: 'SF Mono', 'Fira Code', monospace;
}

pre {
    padding: 16px;
    border-radius: 8px;
    overflow-x: auto;
    border: 1px solid #30363d;
}

/* Position-aware: alternating subtle tints on content slides only */
.slide:nth-child(odd):not(.title-slide):not(.conclusion-slide):not(.section-slide) {
    background-color: rgba(255, 255, 255, 0.02);
}

.slide:nth-child(even):not(.title-slide):not(.conclusion-slide):not(.section-slide) {
    background-color: rgba(0, 0, 0, 0.1);
}

/* Progress-aware accent shift — uses --slide-progress set by slyds.js */
.slide h1 {
    border-bottom-color: color-mix(in srgb, #00d4ff calc(100% - var(--slide-progress, 0%)), #e040fb var(--slide-progress, 0%));
}
