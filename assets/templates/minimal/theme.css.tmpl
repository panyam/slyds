/* {{.Title}} — Minimal theme
   Clean, distraction-free. Maximum readability. */

body {
    background: #ffffff;
    font-family: 'Georgia', 'Times New Roman', serif;
}

.slideshow-container {
    background: #ffffff;
    box-shadow: none;
    border: 1px solid #e0e0e0;
    border-radius: 0;
}

.slide h1 {
    color: #111111;
    font-size: 2.2em;
    border-bottom: 2px solid #111111;
    padding-bottom: 12px;
}

.slide h2 {
    color: #333333;
}

.slide p, .slide li {
    color: #222222;
    font-size: 1.15em;
    line-height: 1.7;
}

.title-slide {
    background: #ffffff;
    color: #111111;
}

.title-slide h1 {
    color: #111111;
    font-size: 2.8em;
    border-bottom: 3px solid #111111;
}

.conclusion-slide {
    background: #f5f5f5;
    color: #111111;
}

.conclusion-slide h1, .conclusion-slide h2 {
    color: #111111;
}

.section-slide {
    background: #f9f9f9;
    color: #111111;
}

.section-slide h1 {
    color: #111111;
    border-bottom: 2px solid #111111;
}

.nav-button {
    background: #111111;
    border-radius: 4px;
}

.nav-button:hover {
    background: #333333;
}

.controls-bar {
    background: rgba(0, 0, 0, 0.05);
}

.controls-bar .presenter-mode-btn {
    background: #333333;
}

.controls-bar .presenter-mode-btn:hover {
    background: #111111;
}

.highlight {
    background: #f5f5f5;
    border-left: 4px solid #111111;
}

/* Position-aware: subtle alternating backgrounds on content slides only */
.slide:nth-child(even):not(.title-slide):not(.conclusion-slide):not(.section-slide) {
    background: #fafafa;
}
