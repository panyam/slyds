/* {{.Title}} — Corporate theme
   Clean, professional. Muted blues and grays for business presentations. */

body {
    background: #f0f2f5;
    font-family: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
}

.slideshow-container {
    background: #ffffff;
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}

.slide h1 {
    color: #1a1a1a;
    font-size: 2.2em;
    border-bottom: 3px solid #0066cc;
    font-weight: 600;
}

.slide h2 {
    color: #333333;
    font-weight: 600;
}

.slide h3 {
    color: #0066cc;
}

.slide p, .slide li {
    color: #444444;
    font-size: 1.1em;
    line-height: 1.7;
}

.title-slide {
    background: linear-gradient(135deg, #003366 0%, #004488 50%, #0066cc 100%);
    color: #ffffff;
}

.title-slide h1 {
    color: #ffffff;
    border-bottom: 3px solid rgba(255, 255, 255, 0.4);
    font-size: 2.6em;
}

.conclusion-slide {
    background: linear-gradient(135deg, #003366 0%, #1a1a2e 100%);
    color: #ffffff;
}

.conclusion-slide h1, .conclusion-slide h2,
.conclusion-slide p, .conclusion-slide li {
    color: #ffffff;
}

.section-slide {
    background: linear-gradient(135deg, #0066cc 0%, #004488 100%);
    color: #ffffff;
}

.section-slide h1, .section-slide p, .section-slide li {
    color: #ffffff;
}

.section-slide h1 {
    border-bottom: 3px solid rgba(255, 255, 255, 0.4);
}

.title-slide p, .title-slide li {
    color: rgba(255, 255, 255, 0.85);
}

.nav-button {
    background: #0066cc;
    border-radius: 6px;
}

.nav-button:hover {
    background: #004488;
}

.controls-bar {
    background: rgba(0, 51, 102, 0.15);
}

.controls-bar .presenter-mode-btn {
    background: #0066cc;
    font-weight: 600;
}

.controls-bar .presenter-mode-btn:hover {
    background: #004488;
}

.highlight {
    background: #f0f6ff;
    border-left: 4px solid #0066cc;
}

.stat-number {
    color: #0066cc;
}

.tier-table th {
    background: #003366;
}

/* Position-aware: alternating row-like backgrounds */
.slide:nth-child(even) {
    background: #f8f9fb;
}

.slide:nth-child(odd) {
    background: #ffffff;
}
