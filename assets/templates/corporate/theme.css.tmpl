/* {{.Title}} — Corporate theme
   Structural overrides that can't be expressed as CSS variables. */

/* Title slide — semi-transparent border */
.title-slide h1 {
    border-bottom: 3px solid rgba(255, 255, 255, 0.4);
    font-size: 2.6em;
}

/* Section slide text + border */
.section-slide h1 {
    border-bottom: 3px solid rgba(255, 255, 255, 0.4);
}

/* Position-aware: alternating backgrounds on content slides */
.slide:nth-child(even):not(.title-slide):not(.conclusion-slide):not(.section-slide) {
    background: var(--slyds-bg-secondary);
}

.slide:nth-child(odd):not(.title-slide):not(.conclusion-slide):not(.section-slide) {
    background: var(--slyds-bg);
}
