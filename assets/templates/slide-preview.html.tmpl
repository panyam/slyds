<!DOCTYPE html>
<html lang="en" data-theme="{{.Theme}}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{.Title}}</title>
  <style>{{.BaseCSS}}</style>
  <style>{{.ThemeCSS}}</style>
  <style>
    /* Single-slide preview: make the slide visible without slyds.js navigation */
    body { margin: 0; background: var(--bg, #1a1a2e); }
    .slide { display: flex !important; opacity: 1 !important; }
    .slideshow-container { width: 100vw; height: 100vh; overflow: hidden; }
  </style>
</head>
<body>
  <div class="slideshow-container">
    {{.SlideHTML}}
  </div>
</body>
</html>
