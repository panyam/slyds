/* {{.Title}} — Minimal theme
   Structural overrides that can't be expressed as CSS variables. */

/* Minimal uses border instead of shadow */
.slideshow-container {
    border: 1px solid var(--slyds-divider);
}

/* Position-aware: subtle alternating backgrounds on content slides */
.slide:nth-child(even):not(.title-slide):not(.conclusion-slide):not(.section-slide) {
    background: var(--slyds-bg-secondary);
}
